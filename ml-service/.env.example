# Environment variables untuk ml-service
# Salin file ini ke .env dan isi nilainya

# Port service berjalan (default: 8001)
PORT=8001

# URL database PostgreSQL - SAMA dengan Node.js backend
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Path ke folder ml-models yang berisi .onnx files
# Relative dari folder ml-service/ atau absolute path
MODEL_DIR=../../ml-models

# Threshold cosine similarity untuk dianggap match (default: 0.40)
MATCH_THRESHOLD=0.40

# Minimum confidence score untuk face detection (default: 0.5)
DETECTION_THRESHOLD=0.5
