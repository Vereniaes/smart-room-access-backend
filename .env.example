# NOTE : CREATE TWO .ENV FILES
# .env.development.local
# .env.production.local

# ENVIRONMENT
NODE_ENV="development"
PORT="5000"

API_KEY=

# DATABASE
DATABASE_URL=

# GCP Cloud Storage
GCP_BUCKET_NAME=capture-security

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=

# JWT
JWT_SECRET=
REFRESH_TOKEN=

# ML Service
# default local: http://localhost:8001
# cloud run: https://ml-service-iot-room-196827089960.asia-southeast2.run.app
ML_SERVICE_URL=https://ml-service-iot-room-196827089960.asia-southeast2.run.app

# HMAC Secret untuk hash RFID UID (wajib diisi, generate dengan: node -e "require('crypto').randomBytes(32).toString('hex')")
HMAC_SECRET=