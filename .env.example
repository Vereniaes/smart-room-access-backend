# NOTE : CREATE TWO .ENV FILES
# .env.development.local
# .env.production.local

# ENVIRONMENT
NODE_ENV="development"
PORT="5000"

API_KEY=

# DATABASE
DATABASE_URL=

# GCP Cloud Storage
GCP_BUCKET_NAME=capture-security

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=

# JWT
JWT_SECRET=
REFRESH_TOKEN=

# ML Service (Python FastAPI - jalankan terpisah di port 8001)
ML_SERVICE_URL=http://localhost:8001

# HMAC Secret untuk hash RFID UID (wajib diisi, generate dengan: node -e "require('crypto').randomBytes(32).toString('hex')")
HMAC_SECRET=